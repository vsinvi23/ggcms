SERVER_PORT=1337
GIN_MODE=debug
LOG_LEVEL=debug
LOG_FILE=logs/app.log

DB_WRITE_URL=postgres://go_cms_user:go_cms_pass@localhost:5433/go_cms?sslmode=disable
DB_READ_URL=

MONGO_URI=mongodb://go_cms_user:go_cms_pass@localhost:27017/?authSource=admin
MONGO_DATABASE=go_cms

JWT_SECRET=go-cms-dev-jwt-secret-min-32-chars-ok
JWT_EXPIRY_HOURS=24

UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:1337/uploads

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://localhost:8081

# Master admin — created automatically on startup if not already in DB
# Change these before first run; password update takes effect on next restart
ADMIN_EMAIL=geekadmin@geekgully.com
ADMIN_PASSWORD=Geekadmin@2026
ADMIN_NAME="Geek Admin"
