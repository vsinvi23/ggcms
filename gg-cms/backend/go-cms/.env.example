# Server
SERVER_PORT=8080
GIN_MODE=debug
# LOG_LEVEL controls verbosity: debug | info | warn | error
# debug → dumps every SQL query + full HTTP request/response bodies
LOG_LEVEL=info

# PostgreSQL (Write/Primary)
# Docker Compose default: gg_cms_user / gg_cms_pass
DB_WRITE_URL=postgres://gg_cms_user:gg_cms_pass@localhost:5433/gg_cms?sslmode=disable

# PostgreSQL (Read Replica - optional, falls back to write DB if not set)
DB_READ_URL=

# MongoDB
# Docker Compose default: gg_cms_user / gg_cms_pass
MONGO_URI=mongodb://gg_cms_user:gg_cms_pass@localhost:27017
MONGO_DATABASE=gg_cms

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY_HOURS=24

# File Upload
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:8080/uploads

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Local dev/test helpers
# Set BYPASS_RATE_LIMIT=1 to skip auth rate limiting during local e2e/troubleshooting runs.
BYPASS_RATE_LIMIT=1

# Master admin — created automatically on startup if not already in DB
# Change these before first run; password update takes effect on next restart
ADMIN_EMAIL=admin@serenya.com
ADMIN_PASSWORD=change-me-in-production
ADMIN_NAME=Super Admin

# ─── Social Login (OAuth2) ──────────────────────────────────────────────────
# Frontend URL — where the backend redirects after OAuth callback
FRONTEND_URL=http://localhost:5173

# Google OAuth — https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match the Authorised redirect URI configured in the Google Cloud Console
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# GitHub OAuth — https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Must match the Authorization callback URL configured in the GitHub OAuth App
GITHUB_REDIRECT_URL=http://localhost:8080/api/auth/github/callback
