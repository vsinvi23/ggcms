# ─── API ──────────────────────────────────────────────────────────────────────
# Full Strapi API URL including /api suffix. Used as the axios baseURL.
VITE_API_BASE_URL=http://localhost:1337/api

# Bare Strapi server URL WITHOUT the /api suffix.
# Used to build absolute media/upload file URLs (e.g. thumbnails served by Strapi).
# If omitted, derived from VITE_API_BASE_URL by stripping the /api suffix.
VITE_STRAPI_URL=http://localhost:1337

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Name of the administrator group in Strapi.
# Must match the group name in the database (comparison is case-insensitive).
VITE_ADMIN_GROUP_NAME=Admin

# ─── Feature flags ─────────────────────────────────────────────────────────────
VITE_ENABLE_REGISTRATION=true
VITE_ENABLE_SOCIAL_LOGIN=false

# ─── App metadata ──────────────────────────────────────────────────────────────
VITE_APP_NAME=GeekGully CMS
VITE_APP_ENV=development
