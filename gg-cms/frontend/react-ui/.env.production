# Production environment — override these via CI env vars or Docker build args.
# VITE_API_BASE_URL is baked into the bundle at build time; it MUST point to
# the publicly reachable backend URL before running `npm run build`.

VITE_API_BASE_URL=https://api.yourdomain.com/api

VITE_APP_NAME=GeekGully
VITE_APP_ENV=production
VITE_ENABLE_REGISTRATION=true
VITE_ENABLE_SOCIAL_LOGIN=false
