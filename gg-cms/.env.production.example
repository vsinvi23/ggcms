# Production Environment Variables
# Copy this file to .env and update with your actual values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_CLIENT=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=strapi_production
DATABASE_USERNAME=strapi
# Generate secure password: openssl rand -base64 32
DATABASE_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# ============================================
# STRAPI SECRETS
# Generate these with: openssl rand -base64 32
# ============================================
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
ADMIN_JWT_SECRET=CHANGE_ME_ADMIN_JWT_SECRET_MIN_32_CHARS
API_TOKEN_SALT=CHANGE_ME_API_TOKEN_SALT
TRANSFER_TOKEN_SALT=CHANGE_ME_TRANSFER_TOKEN_SALT

# APP_KEYS should be comma-separated (minimum 4 keys)
# Generate with: node -e "console.log(Array(4).fill(null).map(() => require('crypto').randomBytes(16).toString('base64')).join(','))"
APP_KEYS=key1_CHANGE_ME,key2_CHANGE_ME,key3_CHANGE_ME,key4_CHANGE_ME

# ============================================
# NODE ENVIRONMENT
# ============================================
NODE_ENV=production

# ============================================
# FRONTEND CONFIGURATION
# ============================================
VITE_API_URL=http://localhost:1337

# ============================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@example.com
# SMTP_PASSWORD=your-smtp-password

# S3_ACCESS_KEY_ID=your-s3-access-key
# S3_SECRET_ACCESS_KEY=your-s3-secret-key
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
