# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in all required values before deploying.

# Docker Compose project name — all containers, networks, and volumes are
# grouped under this namespace (shown in `docker compose ps` and Docker Desktop)
COMPOSE_PROJECT_NAME=gg-cms

# PostgreSQL password for gg_cms_user
POSTGRES_PASSWORD=change_me_postgres

# MongoDB password for gg_cms_user
MONGO_PASSWORD=change_me_mongo

# JWT signing secret — minimum 32 random characters
JWT_SECRET=change_me_jwt_secret_min_32_characters_here

# Master admin — created automatically on first backend start
# ADMIN_PASSWORD must be set — seeding is skipped when empty
ADMIN_EMAIL=admin@gg-cms.local
ADMIN_PASSWORD=change_me_admin_password
ADMIN_NAME=Super Admin

# Secondary admin (optional — used by tests and secondary operators)
# Leave GEEK_ADMIN_PASSWORD empty to disable this account entirely
GEEK_ADMIN_EMAIL=
GEEK_ADMIN_PASSWORD=
GEEK_ADMIN_NAME=Geek Admin

# ── PORTS ─────────────────────────────────────────────────────────────────────
# Change if defaults conflict with other services on the host

FRONTEND_PORT=80
FRONTEND_PORT_HTTPS=443
BACKEND_PORT=8443
PGADMIN_PORT=5050

# ── FRONTEND BUILD ────────────────────────────────────────────────────────────
# /api  → nginx proxies /api/* → backend (recommended for single-host)
# Use a full URL (http://api.example.com/api) only for multi-host deployments
VITE_API_BASE_URL=/api

VITE_APP_NAME=GeekGully CMS
VITE_ENABLE_REGISTRATION=true
VITE_ENABLE_SOCIAL_LOGIN=false
VITE_ADMIN_GROUP_NAME=Admin

# ── BACKEND ───────────────────────────────────────────────────────────────────
# Public URL where uploaded files are served (update for remote deployments)
UPLOAD_BASE_URL=http://localhost/uploads

# CORS origins accepted by the backend API (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost

# Backend URL sent to OAuth providers after callback
FRONTEND_URL=http://localhost

# Optional PostgreSQL read replica — leave empty to use write DB
DB_READ_URL=

# Token lifetime
JWT_EXPIRY_HOURS=24

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info

# ── PGADMIN (optional — only used with --profile tools) ───────────────────────
PGADMIN_EMAIL=admin@gg-cms.local
PGADMIN_PASSWORD=Admin@123

# ── OAUTH (optional — leave empty to disable) ─────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8443/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=http://localhost:8443/api/auth/github/callback
