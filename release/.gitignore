# ── Secrets — never commit ────────────────────────────────────────────────────
.env

# Backend runtime override (may contain secrets)
config/backend/app.env

# ── Runtime data — populated at deploy time ───────────────────────────────────
data/

# ── Build artifacts — generated by build.sh / build.ps1 ──────────────────────
# Compiled Go server binaries
dist/bin/
dist/native/server.exe
dist/native/server

# Pre-built React bundle
dist/frontend/

# Docker image tarballs (too large for git)
dist/images/

# ── Generated certificates — created by certs/generate-certs.sh ──────────────
# (certs/ subdir has its own .gitignore that excludes *.key *.crt *.pem)
