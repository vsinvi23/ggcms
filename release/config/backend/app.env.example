# Backend override configuration
#
# This file is mounted read-only at /app/.env inside the backend container.
# The compose `environment:` section takes precedence for all vars already defined there.
# Uncomment a line here ONLY to add an extra variable or override a compose value.
#
# Copy to app.env (already done by deploy script on first run).
# All vars below are commented out — the defaults from docker-compose.yml are used.

# ── Server ────────────────────────────────────────────────────────────────────
# SERVER_PORT=8080
# GIN_MODE=release
# LOG_LEVEL=info

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# DB_WRITE_URL=postgres://gg_cms_user:password@postgres:5432/gg_cms?sslmode=disable
# DB_READ_URL=

# ── MongoDB ───────────────────────────────────────────────────────────────────
# MONGO_URI=mongodb://gg_cms_user:password@mongodb:27017/?authSource=admin
# MONGO_DATABASE=gg_cms

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT_SECRET=
# JWT_EXPIRY_HOURS=24

# ── Uploads ───────────────────────────────────────────────────────────────────
# UPLOAD_DIR=/app/uploads
# UPLOAD_BASE_URL=http://localhost/uploads

# ── CORS ──────────────────────────────────────────────────────────────────────
# CORS_ALLOWED_ORIGINS=http://localhost

# ── Admin seed ────────────────────────────────────────────────────────────────
# ADMIN_EMAIL=admin@gg-cms.local
# ADMIN_PASSWORD=
# ADMIN_NAME=Super Admin

# ── OAuth ─────────────────────────────────────────────────────────────────────
# FRONTEND_URL=http://localhost
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URL=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URL=

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Set to 1 only for local testing — never in production
# BYPASS_RATE_LIMIT=0
