SERVER_PORT=1337
GIN_MODE=release
LOG_LEVEL=info
LOG_FILE=logs/app.log

# PostgreSQL — matches docker-compose.native.yml (host port 5433)
DB_WRITE_URL=postgres://gg_cms_user:gg_cms_pass@localhost:5433/gg_cms?sslmode=disable
DB_READ_URL=

# MongoDB — matches docker-compose.native.yml (port 27017)
MONGO_URI=mongodb://gg_cms_user:gg_cms_pass@localhost:27017/?authSource=admin
MONGO_DATABASE=gg_cms

# CHANGE BEFORE PRODUCTION USE — must be at least 32 characters
JWT_SECRET=change-me-min-32-characters-required!
JWT_EXPIRY_HOURS=24

UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:1337/uploads

CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80

# Admin account auto-created on first startup
ADMIN_EMAIL=admin@gg-cms.local
ADMIN_PASSWORD=change-me-admin-password
ADMIN_NAME=Super Admin

# Secondary admin — leave GEEK_ADMIN_PASSWORD empty to disable
GEEK_ADMIN_EMAIL=
GEEK_ADMIN_PASSWORD=
GEEK_ADMIN_NAME=Geek Admin
